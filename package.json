    "p-limit": "^7.3.0",
    "svgo": "^4.0.1"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^8.1.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3"
